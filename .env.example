# Application
APP_NAME=Personal Learning OS API
APP_VERSION=0.1.0
APP_ENVIRONMENT=development
LOG_LEVEL=INFO

# Published service addresses and ports
FRONTEND_PORT=3000
BACKEND_PORT=8000
POSTGRES_PORT=5432
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8000
FRONTEND_ORIGIN=http://localhost:3000

# PostgreSQL local development values. Replace the password outside local development.
POSTGRES_DB=plos
POSTGRES_USER=plos
POSTGRES_PASSWORD=plos_local_dev
DATABASE_URL=postgresql+asyncpg://plos:plos_local_dev@localhost:5432/plos

# Idempotent single-user MVP seed
LOCAL_USER_ID=00000000-0000-4000-8000-000000000001
LOCAL_USER_EMAIL=local@personal-learning-os.test
LOCAL_USER_DISPLAY_NAME=Local User
LOCAL_USER_TIMEZONE=Europe/Moscow
